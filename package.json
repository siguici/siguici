{
  "name": "siguici-monorepo",
  "description": "Sigui Kessé Emmanuel's personal monorepo",
  "engines": {
    "node": ">=24.17",
    "nub": ">=0.1"
  },
  "packageManager": "nub@0.1.4",
  "publishConfig": {
    "access": "public"
  },
  "private": true,
  "type": "module",
  "homepage": "https://sigui.deno.dev",
  "repository": "https://github.com/siguici/siguici",
  "scripts": {
    "check": "biome ci .",
    "check:format": "biome format .",
    "check:lint": "biome check .",
    "deploy": "deployctl deploy --project=siguici --no-static --include=./apps/ ./apps/backend/start.ts",
    "fix": "nub run lint && nub run format",
    "fix:unsafe": "biome lint --write --unsafe",
    "format": "biome format --write .",
    "lint": "biome check --write .",
    "serve": "deno run -A ./apps/backend/start.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "nub",
      "version": "^0.1.4",
      "onFail": "warn"
    }
  },
  "workspaces": [
    "apps/*",
    "docs"
  ],
  "allowBuilds": {
    "esbuild": true,
    "sharp": true
  }
}
